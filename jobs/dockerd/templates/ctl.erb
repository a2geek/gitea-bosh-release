#!/bin/bash

RUN_DIR=/var/vcap/sys/run/dockerd
LOG_DIR=/var/vcap/sys/log/dockerd
PIDFILE=${RUN_DIR}/pid

case $1 in

  start)
    # NOTE: start does not clean up from any failed prior run...

    mkdir -p $RUN_DIR $LOG_DIR
    chown -R vcap:vcap $RUN_DIR $LOG_DIR

    echo $$ > $PIDFILE

    source /var/vcap/packages/docker/bosh/runtime.env

    exec dockerd \
        --config-file /var/vcap/jobs/dockerd/config/config.json \
        --data-root /var/vcap/data/dockerd \
        --exec-root /var/vcap/sys/run/dockerd \
        --group vcap \
        --host unix://${RUN_DIR}/docker.sock
      >>  $LOG_DIR/dockerd.stdout.log \
      2>> $LOG_DIR/dockerd.stderr.log

    ;;

  stop)
    kill -9 `cat $PIDFILE`
    rm -f $PIDFILE

    ;;

  *)
    echo "Usage: ctl {start|stop}" ;;

esac
